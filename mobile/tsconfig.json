{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "@wdio/globals/types", "@wdio/cucumber-framework"]
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "reports"]
}
